{
  "manifest_version": 3,
  "name": "Brutus TradingView Alert Helper",
  "version": "0.1.0",
  "description": "Manual-assisted TradingView alert setup helper for Brutus Playbook Alerts.",
  "permissions": ["downloads", "storage"],
  "host_permissions": ["https://www.tradingview.com/chart/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.tradingview.com/chart/*"],
      "js": ["content.js"],
      "css": ["panel.css"],
      "run_at": "document_idle"
    }
  ]
}
